;; kuni-umi 国産 — audit_witness cell (langgraph, WASM runtime)
;; ADR-2605201400 · Phase 2 scaffold
{:cell/id "audit_witness"
 :cell/glyph "🔐"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "src/kuni_umi/cells/audit_witness/cell.cljc"
 :cell/handler "handle_audit_witness"
 :cell/doc "Continuous on-site witness during operational deployment (R1+ real motion). Intake :commissioningRecord (passed) + live sensor feeds (simulated in R0, real RTSP/LiDAR in R1+) → analyze for safety violations (Murakumo anomaly detection) → output :auditRecord with ≥2 robot-DID witness signatures (constitutional, G8). Constitutional invariant: any N=1 record rejected + Council Lv6+ escalation. Stops at :intent in R0; no live enforcement until R1."
 :cell/state-graph
 {:nodes [:intake-commissioning :monitor-feeds :analyze-anomalies :record-event :witness-quorum :output-audit]
  :entry :intake-commissioning
  :edges [[:intake-commissioning :monitor-feeds]
          [:monitor-feeds :analyze-anomalies]
          [:analyze-anomalies :record-event]
          [:record-event :witness-quorum]
          [:witness-quorum :output-audit]
          [:output-audit :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G5" "G6" "G8" "G13" "G14" "G15" "G17"]
 :cell/kotoba
 {:reads [:commissioning/state :sensor/feed :robot/motion-bounds]
  :writes [:audit/id :audit/anomaly-log :audit/witness-sigs :audit/state]}}
