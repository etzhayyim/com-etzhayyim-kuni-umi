;; kuni-umi 国産 — commissioning cell (langgraph, WASM runtime)
;; ADR-2605201400 · Phase 2 scaffold
{:cell/id "commissioning"
 :cell/glyph "✅"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "src/kuni_umi/cells/commissioning/cell.cljc"
 :cell/handler "handle_commissioning"
 :cell/doc "Intake :constructionRecord (ready-qc) → run commissioning checklist (safety PLCs + motion bounds + sensor calibration simulation, Murakumo rewrite) → generate :commissioningRecord with ≥2 robot-DID witness signatures + operator attestation (G8/G13/G15) → transition :commissioning/state from :in-progress → :passed | :failed. Stops at :passed intent; no live operation until member consent + Council Lv6+ gate (R1+)."
 :cell/state-graph
 {:nodes [:intake-construction :run-checklist :validate-pnp :record-attestation :witness-sign :output-result]
  :entry :intake-construction
  :edges [[:intake-construction :run-checklist]
          [:run-checklist :validate-pnp]
          [:validate-pnp :record-attestation]
          [:record-attestation :witness-sign]
          [:witness-sign :output-result]
          [:output-result :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G5" "G6" "G8" "G13" "G14" "G15"]
 :cell/kotoba
 {:reads [:construction/state :robot/safety-pnp]
  :writes [:commissioning/id :commissioning/checklist-result :commissioning/witness-sigs :commissioning/state]}}
