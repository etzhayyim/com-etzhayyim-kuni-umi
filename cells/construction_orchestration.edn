;; kuni-umi 国産 — construction_orchestration cell (langgraph, WASM runtime)
;; ADR-2605201400 · Phase 2 scaffold
{:cell/id "construction_orchestration"
 :cell/glyph "🏗️"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "src/kuni_umi/cells/construction_orchestration/cell.cljc"
 :cell/handler "handle_construction_orchestration"
 :cell/doc "Intake :deploymentIntent (member-signed, intent → pending-dispatch) → coordinate Giemon robot motion tasks via kotoba event log (no direct motion in R0; G1 consent gate) → simulate progress updates (Murakumo LLM task reasoning) → build :constructionRecord with ≥2 robot-DID witness signatures (mandatory, constitutional, G8). Output transitions :constructionRecord/state from :in-progress → :ready-qc. No actual robot dispatch until R1+."
 :cell/state-graph
 {:nodes [:intake-intent :simulate-tasks :coordinate-sequencing :record-progress :witness-signing :output-record]
  :entry :intake-intent
  :edges [[:intake-intent :simulate-tasks]
          [:simulate-tasks :coordinate-sequencing]
          [:coordinate-sequencing :record-progress]
          [:record-progress :witness-signing]
          [:witness-signing :output-record]
          [:output-record :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G5" "G6" "G8" "G13" "G15" "G17"]
 :cell/kotoba
 {:reads [:deployment/robot-roster :deployment/sequence-plan]
  :writes [:construction/id :construction/progress :construction/witness-sigs :construction/state]}}
