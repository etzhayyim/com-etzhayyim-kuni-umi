;; kuni-umi 国産 — deployment_planning cell (langgraph, WASM runtime)
;; ADR-2605201400 · Phase 2 scaffold
{:cell/id "deployment_planning"
 :cell/glyph "📐"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/entry "py/agent.py"
 :cell/handler "handle_deployment_planning"
 :cell/doc "Intake :siteAttestation → Giemon fleet composition planning (Otete/Mimi/Watari/Awa/Hitogata/Quad) + motion sequence simulation (Murakumo LLM rewrite) + safety margin attestation (≥2 independent robot witness signatures mandatory before real-world binding, G8). Output :deploymentIntent (state :planned, unsigned). Stops at intent — member signature required (G14/G15)."
 :cell/state-graph
 {:nodes [:parse-site :select-robots :plan-sequence :validate-safety :build-intent]
  :entry :parse-site
  :edges [[:parse-site :select-robots]
          [:select-robots :plan-sequence]
          [:plan-sequence :validate-safety]
          [:validate-safety :build-intent]
          [:build-intent :end]]}
 :cell/llm
 {:provider :murakumo
  :endpoint "127.0.0.1:4000"
  :model "gemma3:4b"
  :charter-rider true}
 :cell/gates ["G1" "G5" "G6" "G8" "G14" "G15"]
 :cell/kotoba
 {:reads [:site/baseline-attestation :robot/capabilities :robot/availability]
  :writes [:deployment/id :deployment/robot-roster :deployment/sequence-plan :deployment/state]}}
