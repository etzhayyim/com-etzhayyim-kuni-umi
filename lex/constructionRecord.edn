{:lexicon 1
 :id "com.etzhayyim.kuniumi.constructionRecord"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["constructionId" "deploymentIntentId" "progressLog" "state"]
    :properties
    {:constructionId      {:type "string" :description "unique construction record ID"}
     :deploymentIntentId  {:type "string" :description "ref to :deploymentIntent"}
